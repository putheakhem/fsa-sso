{
    "name": "putheakhem/fsa-sso",
    "description": "Laravel package for integrating FSA SSO authentication",
    "keywords": [
        "laravel",
        "fsa",
        "sso",
        "jwks",
        "authentication"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Putheakhem",
            "email": "puthea.khem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^7.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "firebase/php-jwt": "^7.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PutheaKhem\\FsaSso\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PutheaKhem\\FsaSso\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PutheaKhem\\FsaSso\\FsaSsoServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
